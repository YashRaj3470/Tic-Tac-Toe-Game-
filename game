    }

    // piano-style note with simple harmonic content and ADSR envelope
    private static void playPianoNote(final int hz, final int msecs) {
        new Thread(() -> {
            try {
                float SAMPLE_RATE = 44100;
                byte[] buf = new byte[1];
                AudioFormat af = new AudioFormat(SAMPLE_RATE, 8, 1, true, false);
                SourceDataLine sdl = AudioSystem.getSourceDataLine(af);
                sdl.open(af);
                sdl.start();

                int total = msecs * (int)SAMPLE_RATE / 1000;
                double duration = msecs / 1000.0;
                // ADSR parameters
                double attack = Math.min(0.02, duration * 0.1);
                double decay = Math.min(0.05, duration * 0.2);
                double sustainLevel = 0.6;
                double release = Math.min(0.1, duration * 0.3);

                for (int i = 0; i < total; i++) {
                    double t = i / SAMPLE_RATE;
                    double angle = t * hz * 2.0 * Math.PI;
                    // add a bit of second harmonic for timbre
                    double signal = Math.sin(angle) + 0.5 * Math.sin(2 * angle);

                    // envelope
                    double env;
                    if (t < attack) {
                        env = (t / attack);
                    } else if (t < attack + decay) {
                        env = 1 - (1 - sustainLevel) * ((t - attack) / decay);
                    } else if (t < duration - release) {
                        env = sustainLevel;
                    } else {
                        env = sustainLevel * ((duration - t) / release);
                    }

                    buf[0] = (byte) (signal * 127 * env);
                    sdl.write(buf, 0, 1);
                }
                sdl.drain();
                sdl.stop();
                sdl.close();
            } catch (Exception e) {
                e.printStackTrace();
            }
        }).start();
    }


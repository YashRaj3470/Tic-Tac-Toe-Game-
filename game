    // helper method to synthesize a tone (simple sine wave) of given frequency/duration
    private static void playTone(final int hz, final int msecs) {
        new Thread(() -> {
            try {
                float SAMPLE_RATE = 44100;
                byte[] buf = new byte[1];
                AudioFormat af = new AudioFormat(SAMPLE_RATE, 8, 1, true, false);
                SourceDataLine sdl = AudioSystem.getSourceDataLine(af);
                sdl.open(af);
                sdl.start();

                int totalSamples = msecs * (int)SAMPLE_RATE / 1000;
                double durationSec = msecs / 1000.0;
                // make attack/release a bit longer and use cosine ramps for smoothness
                double attackSec = Math.min(0.05, durationSec * 0.2);   // up to 50ms or 20%
                double releaseSec = Math.min(0.1, durationSec * 0.3);   // up to 100ms or 30%

                for (int i = 0; i < totalSamples; i++) {
                    double t = i / SAMPLE_RATE;
                    double angle = t * hz * 2.0 * Math.PI;

                    // base exponential decay to keep tone from ringing forever
                    double envelope = Math.exp(-3.0 * t / durationSec);

                    // smooth cosine attack
                    if (t < attackSec) {
                        double x = t / attackSec;
                        envelope *= 0.5 * (1 - Math.cos(Math.PI * x));
                    }
                    // smooth cosine release
                    if (t > durationSec - releaseSec) {
                        double x = (durationSec - t) / releaseSec;
                        envelope *= 0.5 * (1 - Math.cos(Math.PI * x));
                    }

                    buf[0] = (byte) (Math.sin(angle) * 127 * envelope);
                    sdl.write(buf, 0, 1);
                }
                sdl.drain();
                sdl.stop();
                sdl.close();
            } catch (Exception e) {
                e.printStackTrace();
            }
        }).start();
    }


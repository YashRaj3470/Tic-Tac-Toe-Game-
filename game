            }
        } else if (game.isBoardFull()) {
            statusLabel.setText("Draw!");
            playDrawSound();
            animateStatus();
            int choice = JOptionPane.showOptionDialog(this,
                    "It's a draw!\nPlay again?",
                    "Game Over",
                    JOptionPane.YES_NO_OPTION,
                    JOptionPane.INFORMATION_MESSAGE,
                    null,
                    new Object[]{"Yes","No"},
                    "Yes");
            if (choice == JOptionPane.YES_OPTION) {
                resetGame();
            } else {
                System.exit(0);
            }
        } else {
            game.switchPlayer();
            statusLabel.setText("Player " + game.getCurrentPlayer() + "'s turn");
            animateStatus();
            if (vsComputer && game.getCurrentPlayer() == 'O') {
                computerMove();
            }
        }
    }

    private void animateStatus() {
        // simple color flash on the label
        final Color normal = statusLabel.getForeground();
        Timer t = new Timer(100, new ActionListener() {
            int count = 0;
            boolean red = false;
            public void actionPerformed(ActionEvent e) {
                statusLabel.setForeground(red ? Color.RED : normal);
                red = !red;
                if (++count >= 6) {
                    ((Timer)e.getSource()).stop();
                    statusLabel.setForeground(normal);
                }
            }
        });
        t.start();
    }

    private void computerMove() {
        int[] move = game.pickRandomMove();
        if (move == null) return;
        // small delay so user sees their mark first
        Timer t = new Timer(400, e -> {
            handleMove(move[0], move[1]);
        });
        t.setRepeats(false);
        t.start();
    }

    private void startBackgroundAnimation() {
        if (bgTimer != null) return; // already running
        bgTimer = new Timer(200, new ActionListener() {
            float hue = 0f;
            public void actionPerformed(ActionEvent e) {
                hue += 0.02f;
                if (hue > 1f) hue = 0f;
                boardPanel.setBackground(Color.getHSBColor(hue, 0.2f, 1f));
            }
        });
        bgTimer.start();
        startBackgroundMusic();
    }

    private void resetGame() {
        game.reset();
        for (int i = 0; i < 3; i++) {
            for (int j = 0; j < 3; j++) {
                buttons[i][j].setText(" ");
            }
        }
        statusLabel.setText("Player " + game.getCurrentPlayer() + "'s turn");
        if (vsComputer && game.getCurrentPlayer() == 'O') {
            computerMove();
        }
    }

    // start looping MIDI piano background using built-in synthesizer
    private void startBackgroundMusic() {
        if (sequencer != null && sequencer.isOpen()) return;
        try {
            sequencer = javax.sound.midi.MidiSystem.getSequencer();
            sequencer.open();
            javax.sound.midi.Sequence seq = new javax.sound.midi.Sequence(javax.sound.midi.Sequence.PPQ, 4);
            javax.sound.midi.Track track = seq.createTrack();

            // simple C major progression, one chord per bar
            int[] chords = {60, 64, 67}; // C E G
            for (int bar = 0; bar < 8; bar++) {
                int tick = bar * 16;
                for (int n : chords) {
                    track.add(makeNoteEvent(144, n, 100, tick)); // note on
                    track.add(makeNoteEvent(128, n, 0, tick + 12)); // note off
                    tick += 4;
                }
            }
            // configure sequencer with our sequence and looping
            sequencer.setSequence(seq);
            sequencer.setLoopCount(javax.sound.midi.Sequencer.LOOP_CONTINUOUSLY);
            sequencer.start();
        } catch (Exception e) {
            e.printStackTrace();
        }
    }

    private void stopBackgroundMusic() {
        if (sequencer != null) {
            sequencer.stop();
            sequencer.close();
        }
    }

    private javax.sound.midi.MidiEvent makeNoteEvent(int command, int pitch, int velocity, int tick) throws javax.sound.midi.InvalidMidiDataException {
        javax.sound.midi.ShortMessage message = new javax.sound.midi.ShortMessage();
        message.setMessage(command, 0, pitch, velocity);
        return new javax.sound.midi.MidiEvent(message, tick);
    }


